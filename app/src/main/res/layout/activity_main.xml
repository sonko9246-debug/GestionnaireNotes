<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Conteneur principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- Barre supérieure : Recherche + Bouton Favoris -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@color/white"
            android:elevation="2dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchView"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:iconifiedByDefault="false"
                android:queryHint="Rechercher une note..."
                app:queryBackground="@android:color/transparent"
                app:searchHintIcon="@null" />

            <ImageButton
                android:id="@+id/button_favorites_filter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_star"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Filtrer les favoris"
                android:layout_marginStart="8dp"
                app:tint="@color/gray" />
        </LinearLayout>

        <!-- Zone de contenu (liste ou état vide) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- État vide -->
            <LinearLayout
                android:id="@+id/empty_state_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/image_empty"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_empty_notes"
                    android:contentDescription="Aucune note"
                    android:alpha="0.4" />

                <TextView
                    android:id="@+id/text_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Aucune notes"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray" />
            </LinearLayout>

            <!-- Liste des notes -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewNotes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:clipToPadding="false"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Palette de couleurs -->
    <LinearLayout
        android:id="@+id/color_palette"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:background="@drawable/bg_color_palette"
        android:padding="12dp"
        android:elevation="8dp"
        android:visibility="invisible"
        android:layout_marginBottom="90dp">
    </LinearLayout>

    <!-- Bouton flottant d'ajout -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Ajouter une note"
        app:backgroundTint="@color/primary"
        app:fabSize="normal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>