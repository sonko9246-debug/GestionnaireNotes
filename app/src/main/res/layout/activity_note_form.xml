<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout du formulaire de création / modification de note.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutFormulaire"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Titre de l'écran -->
    <TextView
        android:id="@+id/tvTitreEcran"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nouvelle note"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Champ TITRE -->
    <EditText
        android:id="@+id/editTitre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Titre de la note"
        android:inputType="textCapSentences"
        android:textSize="16sp"
        android:textColor="#212121"
        android:textColorHint="#757575"
        android:background="@android:color/white"
        android:padding="12dp"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/tvTitreEcran"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Séparateur visuel -->
    <View
        android:id="@+id/separateur1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#BDBDBD"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/editTitre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Champ CONTENU -->
    <EditText
        android:id="@+id/editContenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:hint="Contenu de la note..."
        android:inputType="textMultiLine|textCapSentences"
        android:gravity="top|start"
        android:textSize="14sp"
        android:textColor="#212121"
        android:textColorHint="#757575"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/separateur1"
        app:layout_constraintBottom_toTopOf="@id/btnEnregistrer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bouton Créer / Modifier -->
    <Button
        android:id="@+id/btnEnregistrer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Créer"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#212121"
        android:padding="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>